# File: .env.example
#
# Environment variables for the Docker Compose stack.
# Copy this file to .env and adjust values as needed.
#
# --- General Configuration ---

# Project name used to derive the default base domain.
# The default convention is <PROJECT_NAME>.aladroc.io
PROJECT_NAME=compose-traeffik

# Optional override for docker compose project name.
# Defaults to PROJECT_NAME; if empty, the repo directory name is used.
COMPOSE_PROJECT_NAME=

# Domain name for local development.
# Used by whoami service, Traefik dashboard, and certificate generation.
# IMPORTANT: You must add an entry to your /etc/hosts file (or equivalent)
# mapping this domain to 127.0.0.1 for local resolution.
# Example: 127.0.0.1 whoami.<BASE_DOMAIN> traefik.<BASE_DOMAIN> step-ca.<BASE_DOMAIN>
# Default uses a local-only domain.
DEV_DOMAIN=local.test

# Base domain for loopback subdomain mappings.
# Default uses a local-only domain.
# Keep this aligned with DEV_DOMAIN unless you intentionally separate them.
BASE_DOMAIN=local.test

# Loopback X octet for 127.0.X.Y assignments (0-255).
LOOPBACK_X=10

# Optional comma-separated list of endpoints (order preserved).
# Example: whoami,traefik,stepca,ctfd,grafana,plane,docling,openwebui,awx
ENDPOINTS=whoami,traefik,stepca

# Optional overrides for hosts-subdomains.sh.
# HOSTS_FILE defaults to /etc/hosts
# ENV_FILE defaults to .env (if present) or .env.example
HOSTS_FILE=
ENV_FILE=.env

# Traefik dashboard BasicAuth credentials.
# Leave password blank to auto-generate via `make bootstrap`.
TRAEFIK_DASHBOARD_BASIC_AUTH_USER=admin
TRAEFIK_DASHBOARD_BASIC_AUTH_PASSWORD=

# Path to the htpasswd file used by Traefik BasicAuth for the dashboard (container path).
# Generated during `make bootstrap` if missing.
TRAEFIK_DASHBOARD_BASIC_AUTH_HTPASSWD_PATH=/etc/traefik/auth/traefik-dashboard.htpasswd

# --- Semaphore UI Service Configuration ---

# Semaphore UI image (pin stable release tags).
SEMAPHOREUI_IMAGE=semaphoreui/semaphore:v2.17.14

# Internal PostgreSQL image for Semaphore UI.
SEMAPHOREUI_DB_IMAGE=postgres:16.8-alpine

# Semaphore UI hostname (subdomain only). URL will be https://<hostname>.<DEV_DOMAIN>
SEMAPHOREUI_HOSTNAME=semaphore

# Explicit web root used by Semaphore for reverse-proxy links and OIDC redirects.
# Keep aligned with Traefik route hostname.
SEMAPHOREUI_WEB_ROOT=https://semaphore.${DEV_DOMAIN}

# Semaphore UI bootstrap admin user.
SEMAPHOREUI_ADMIN_LOGIN=admin
SEMAPHOREUI_ADMIN_NAME=Admin
SEMAPHOREUI_ADMIN_EMAIL=admin@localhost
# Leave blank to auto-generate via `make semaphoreui-bootstrap`.
SEMAPHOREUI_ADMIN_PASSWORD=

# Semaphore UI PostgreSQL config (host/service is managed by compose).
SEMAPHOREUI_DB_NAME=semaphore
SEMAPHOREUI_DB_USER=semaphore
# Leave blank to auto-generate via `make semaphoreui-bootstrap`.
SEMAPHOREUI_DB_PASSWORD=

# Required Semaphore crypto/session secrets (leave blank to auto-generate).
SEMAPHOREUI_COOKIE_HASH=
SEMAPHOREUI_COOKIE_ENCRYPTION=
SEMAPHOREUI_ACCESS_KEY_ENCRYPTION=

# Optional local login hardening.
SEMAPHOREUI_PASSWORD_LOGIN_DISABLED=false

# Optional OIDC / Keycloak integration (disabled by default).
SEMAPHOREUI_OIDC_ENABLED=false
SEMAPHOREUI_OIDC_PROVIDER_NAME=keycloak
SEMAPHOREUI_OIDC_DISPLAY_NAME=Keycloak
# Example provider URL (Keycloak realm issuer base):
# SEMAPHOREUI_OIDC_PROVIDER_URL=https://keycloak.${DEV_DOMAIN}/realms/master
SEMAPHOREUI_OIDC_PROVIDER_URL=
SEMAPHOREUI_OIDC_CLIENT_ID=
SEMAPHOREUI_OIDC_CLIENT_SECRET=
SEMAPHOREUI_OIDC_SCOPES=openid,profile,email
SEMAPHOREUI_OIDC_USERNAME_CLAIM=preferred_username
SEMAPHOREUI_OIDC_NAME_CLAIM=name
SEMAPHOREUI_OIDC_EMAIL_CLAIM=email
# Generated by `make semaphoreui-bootstrap` when OIDC is enabled and required values are present.
# Keep `{}` when OIDC is disabled to satisfy Semaphore's JSON parser.
SEMAPHOREUI_OIDC_PROVIDERS_JSON={}

# Optional observability integration hooks (compatible with Grafana/Prometheus/Loki collector pattern).
SEMAPHOREUI_OBSERVABILITY_ENABLED=false
SEMAPHOREUI_OBSERVABILITY_DISCOVERY=labels
# Public telemetry exposure is intentionally unsupported by default for this service module.
SEMAPHOREUI_OBSERVABILITY_PUBLIC_METRICS=false
SEMAPHOREUI_LOG_LEVEL=info

# --- DNS Service (BIND) Configuration ---

# Bind address for BIND port 53 (tcp/udp).
# Example external interface in this environment:
BIND_BIND_ADDRESS=10.64.70.90

# Explicitly allow non-loopback DNS bind address exposure.
# Required when using non-loopback BIND_BIND_ADDRESS.
BIND_ALLOW_NONLOCAL_BIND=true

# Optional loopback override used by runtime security smoke tests.
BIND_SECURITY_TEST_ADDRESS=127.0.10.53

# --- AWX (k3d + AWX Operator) Hybrid Module ---
#
# AWX is not deployed with docker compose directly. This repo uses k3d (K3s in Docker)
# plus AWX Operator, while Traefik (compose) provides the HTTPS edge route.

# Enable rendering of the AWX Traefik route template.
# The AWX scripts set this automatically; keep false by default.
AWX_ENABLED=false

# Public hostname label for AWX behind Traefik.
AWX_HOSTNAME=awx

# Kubernetes namespace and instance name for the AWX custom resource.
AWX_NAMESPACE=awx
AWX_INSTANCE_NAME=awx

# Local k3d cluster name for the AWX module.
AWX_K3D_CLUSTER_NAME=awx

# KUBECONFIG path used by AWX scripts (prefer a gitignored path under .local/).
AWX_KUBECONFIG_PATH=.local/kubeconfigs/awx-k3d.yaml

# AWX service exposure: the AWX web service is created as a Kubernetes NodePort.
# Kubernetes NodePort range is typically 30000-32767.
AWX_NODEPORT_HTTP=30080

# Host port mapped by k3d to the AWX NodePort.
# Keep equal to AWX_NODEPORT_HTTP unless you intentionally decouple them.
AWX_HOST_PORT_HTTP=30080

# AWX initial admin user and repo-managed bootstrap secrets.
# Leave secrets blank to auto-generate via `make awx-bootstrap`.
AWX_ADMIN_USER=admin
AWX_ADMIN_PASSWORD=
AWX_SECRET_KEY=

# Kubernetes secret names created by the AWX scripts.
AWX_ADMIN_PASSWORD_SECRET_NAME=awx-admin-password
AWX_SECRET_KEY_SECRET_NAME=awx-secret-key

# AWX Operator Helm chart installation settings (pin versions explicitly).
AWX_OPERATOR_HELM_REPO_NAME=awx-operator
AWX_OPERATOR_HELM_REPO_URL=https://ansible-community.github.io/awx-operator-helm/
AWX_OPERATOR_RELEASE_NAME=awx-operator
# For the Helm chart-based operator flow used in this repo, keep this equal to AWX_NAMESPACE
# (the chart-scoped operator watches only its own namespace).
AWX_OPERATOR_NAMESPACE=awx
AWX_OPERATOR_CHART_VERSION=3.2.0
# Informational pin references (used for documentation/handoff verification)
AWX_OPERATOR_VERSION_TARGET=2.19.1
AWX_VERSION_TARGET=24.6.1

# k3d/K3s version pin used by `make awx-k3d-up`.
K3D_K3S_IMAGE=rancher/k3s:v1.31.5-k3s1

# Whether AWX projects persistence is enabled in the AWX CR (local lab default is false).
AWX_PROJECTS_PERSISTENCE=false

# AWX day-2 local artifact paths (gitignored).
# Note: operator backup payload stays in-cluster on a backup PVC; these paths store metadata/debug bundles.
AWX_BACKUP_LOCAL_DIR=.local/awx/backups
AWX_DEBUG_LOCAL_DIR=.local/awx/debug

# Day-2 polling timeout for AWXBackup/AWXRestore completion (seconds).
AWX_DAY2_WAIT_TIMEOUT=1800

# --- CTFd Configuration (profile: ctfd) ---

# Hostname label for the CTFd UI (final URL: https://<CTFD_HOSTNAME>.<DEV_DOMAIN>)
CTFD_HOSTNAME=ctfd

# Pinned images for the CTFd module
CTFD_IMAGE=ctfd/ctfd:3.8.1
CTFD_DB_IMAGE=mariadb:10.11.14
CTFD_REDIS_IMAGE=redis:7.2.11-alpine

# CTFd app/database settings
CTFD_DB_NAME=ctfd
CTFD_DB_USER=ctfd
CTFD_WORKERS=1

# Secrets (leave blank to generate with `make ctfd-bootstrap`)
CTFD_SECRET_KEY=
CTFD_DB_PASSWORD=
CTFD_DB_ROOT_PASSWORD=

# --- Observability Configuration (profile: observability) ---

# Grafana public hostname label (final URL: https://<GRAFANA_HOSTNAME>.<DEV_DOMAIN>)
GRAFANA_HOSTNAME=grafana

# Pinned images for the observability module
GRAFANA_IMAGE=grafana/grafana:12.3.2
PROMETHEUS_IMAGE=prom/prometheus:v3.5.1
LOKI_IMAGE=grafana/loki:3.6.3
ALLOY_IMAGE=grafana/alloy:v1.11.2
TEMPO_IMAGE=grafana/tempo:2.6.1
PYROSCOPE_IMAGE=grafana/pyroscope:1.12.0
K6_IMAGE=grafana/k6:0.49.0

# Grafana admin credentials/secrets (leave blank to generate with `make observability-bootstrap`)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_SECRET_KEY=

# Local retention defaults (bounded; override as needed)
PROMETHEUS_RETENTION_TIME=7d
LOKI_RETENTION_PERIOD=168h
TEMPO_RETENTION_PERIOD=168h
PYROSCOPE_RETENTION_PERIOD=168h

# Synthetic check defaults (make observability-k6)
K6_TARGET_URL=https://whoami.${DEV_DOMAIN}
K6_ITERATIONS=10
K6_SLEEP_SECONDS=1
K6_OUT=experimental-prometheus-rw
K6_PROMETHEUS_RW_SERVER_URL=http://prometheus:9090/api/v1/write
K6_PROMETHEUS_RW_TREND_STATS="p(50),p(90),p(95),p(99),min,max,avg"

# --- Plane Configuration (profile: plane) ---

# Public hostname label for Plane (final URL: https://<PLANE_HOSTNAME>.<DEV_DOMAIN>)
PLANE_HOSTNAME=plane

# Upstream Plane release channel for community images.
# Use `stable` by default; override with a tested tag in your environment.
PLANE_APP_RELEASE=stable

# Pinned images for the Plane module
PLANE_FRONTEND_IMAGE=artifacts.plane.so/makeplane/plane-frontend:${PLANE_APP_RELEASE}
PLANE_SPACE_IMAGE=artifacts.plane.so/makeplane/plane-space:${PLANE_APP_RELEASE}
PLANE_ADMIN_IMAGE=artifacts.plane.so/makeplane/plane-admin:${PLANE_APP_RELEASE}
PLANE_LIVE_IMAGE=artifacts.plane.so/makeplane/plane-live:${PLANE_APP_RELEASE}
PLANE_BACKEND_IMAGE=artifacts.plane.so/makeplane/plane-backend:${PLANE_APP_RELEASE}
PLANE_POSTGRES_IMAGE=postgres:15.7-alpine
PLANE_REDIS_IMAGE=valkey/valkey:7.2.11-alpine
PLANE_RABBITMQ_IMAGE=rabbitmq:3.13.6-management-alpine
PLANE_MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z

# Core app/runtime settings
PLANE_POSTGRES_USER=plane
PLANE_POSTGRES_DB=plane
PLANE_POSTGRES_PGDATA=/var/lib/postgresql/data
PLANE_RABBITMQ_USER=plane
PLANE_RABBITMQ_VHOST=plane
PLANE_USE_MINIO=1
PLANE_AWS_REGION=
PLANE_AWS_ACCESS_KEY_ID=access-key
PLANE_AWS_S3_ENDPOINT_URL=http://plane-minio:9000
PLANE_AWS_S3_BUCKET_NAME=uploads
PLANE_FILE_SIZE_LIMIT=5242880
PLANE_API_KEY_RATE_LIMIT=60/minute
PLANE_MINIO_ENDPOINT_SSL=0
PLANE_TRUSTED_PROXIES=0.0.0.0/0
PLANE_MACHINE_SIGNATURE=

# Secrets (leave blank to generate with `make plane-bootstrap`)
PLANE_SECRET_KEY=
PLANE_LIVE_SERVER_SECRET_KEY=
PLANE_POSTGRES_PASSWORD=
PLANE_RABBITMQ_PASSWORD=
PLANE_AWS_SECRET_ACCESS_KEY=

# Optional Keycloak/OIDC integration (disabled by default)
PLANE_OIDC_ENABLED=false
PLANE_KEYCLOAK_MODE=external
PLANE_KEYCLOAK_INTERNAL_URL=http://keycloak:8080
PLANE_KEYCLOAK_EXTERNAL_URL=
PLANE_OIDC_ISSUER=
PLANE_OIDC_CLIENT_ID=
PLANE_OIDC_CLIENT_SECRET=
PLANE_OIDC_REDIRECT_URI=

# Optional observability hooks (no hard dependency on observability profile)
PLANE_OBSERVABILITY_ENABLED=false
PLANE_OBSERVABILITY_METRICS_PATH=/metrics
PLANE_OTEL_EXPORTER_OTLP_ENDPOINT=
PLANE_OTEL_SERVICE_NAME=
PLANE_OTEL_RESOURCE_ATTRIBUTES=

# --- Docling Configuration (profile: docling) ---

# Public hostname label for Docling (final URL: https://<DOCLING_HOSTNAME>.<DEV_DOMAIN>)
DOCLING_HOSTNAME=docling

# Pinned image strategy for Docling module
DOCLING_IMAGE=ghcr.io/docling-project/docling-serve-cpu
DOCLING_IMAGE_TAG=main
DOCLING_REDIS_IMAGE=redis:7.2.11-alpine

# Core runtime settings
DOCLING_ENABLE_UI=true
DOCLING_LOG_LEVEL=WARNING
DOCLING_ENGINE_KIND=local
DOCLING_UVICORN_ROOT_PATH=
DOCLING_MAX_SYNC_WAIT=120
DOCLING_LOAD_MODELS_AT_BOOT=true
DOCLING_ARTIFACTS_PATH=/var/lib/docling/artifacts
DOCLING_SCRATCH_PATH=/var/lib/docling/scratch

# Auth mode: open | api-key | keycloak
DOCLING_AUTH_MODE=api-key
DOCLING_TRAEFIK_MIDDLEWARES=security-headers@file

# Secrets (leave blank to generate with `make docling-bootstrap`)
DOCLING_API_KEY=
DOCLING_REDIS_PASSWORD=

# Optional Keycloak integration (disabled by default)
DOCLING_KEYCLOAK_ENABLED=false
DOCLING_KEYCLOAK_MODE=external
DOCLING_KEYCLOAK_INTERNAL_URL=http://keycloak:8080
DOCLING_KEYCLOAK_EXTERNAL_URL=
DOCLING_KEYCLOAK_CLIENT_ID=
DOCLING_KEYCLOAK_CLIENT_SECRET=
DOCLING_KEYCLOAK_ISSUER=

# Optional observability hooks (no hard dependency on observability profile)
DOCLING_OBSERVABILITY_ENABLED=false
DOCLING_SERVE_OTEL_ENABLE_METRICS=false
DOCLING_SERVE_OTEL_ENABLE_TRACES=false
DOCLING_SERVE_OTEL_ENABLE_PROMETHEUS=false
DOCLING_SERVE_OTEL_SERVICE_NAME=docling-serve
DOCLING_OTEL_EXPORTER_OTLP_ENDPOINT=
DOCLING_PROMETHEUS_METRICS_PATH=/metrics

# --- FreeIPA Configuration (profile: freeipa) ---

# Public hostname label for FreeIPA (final URL: https://<FREEIPA_HOSTNAME>.<DEV_DOMAIN>)
FREEIPA_HOSTNAME=freeipa

# Pinned image strategy for FreeIPA module
FREEIPA_IMAGE=quay.io/freeipa/freeipa-server:fedora-41

# Core runtime settings
FREEIPA_SERVER_HOSTNAME=freeipa.${DEV_DOMAIN}
FREEIPA_SERVER_IP=
FREEIPA_REALM=LOCAL.TEST
FREEIPA_DOMAIN=local.test
FREEIPA_NO_HOST_DNS=true
FREEIPA_AUTO_REVERSE=true
FREEIPA_INSTALL_OPTS=--unattended
FREEIPA_TLS_MODE=stepca-acme
FREEIPA_TRAEFIK_MIDDLEWARES=security-headers@file

# Secrets (leave blank to generate with `make freeipa-bootstrap`)
FREEIPA_ADMIN_PASSWORD=
FREEIPA_DM_PASSWORD=

# Optional Keycloak integration (disabled by default)
FREEIPA_KEYCLOAK_ENABLED=false
FREEIPA_KEYCLOAK_MODE=external
FREEIPA_KEYCLOAK_INTERNAL_URL=http://keycloak:8080
FREEIPA_KEYCLOAK_EXTERNAL_URL=
FREEIPA_KEYCLOAK_CLIENT_ID=
FREEIPA_KEYCLOAK_CLIENT_SECRET=
FREEIPA_KEYCLOAK_ISSUER=

# Optional observability hooks (no hard dependency on observability profile)
FREEIPA_OBSERVABILITY_ENABLED=false
FREEIPA_OTEL_EXPORTER_OTLP_ENDPOINT=
FREEIPA_OTEL_SERVICE_NAME=freeipa
FREEIPA_PROMETHEUS_METRICS_PATH=/metrics

# --- OpenWebUI Configuration (profile: webui) ---

# Public hostname label for OpenWebUI (final URL: https://<OPENWEBUI_HOSTNAME>.<DEV_DOMAIN>)
OPENWEBUI_HOSTNAME=openwebui
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPENWEBUI_ENABLE_SIGNUP=false
OPENWEBUI_ENABLE_PERSISTENT_CONFIG=true
OPENWEBUI_SECRET_KEY=
OPENWEBUI_ADMIN_EMAIL=
OPENWEBUI_ADMIN_PASSWORD=

# Optional model backends
OPENWEBUI_OLLAMA_BASE_URL=
OPENWEBUI_OPENAI_API_BASE_URLS=
OPENWEBUI_OPENAI_API_KEYS=

# Traefik Docker image to use. Prefer a stable major version.
# Example: traefik:v3.0
TRAEFIK_IMAGE=traefik:v3.6.7

# Enable/Disable Traefik Dashboard. Default is true (enabled).
# If enabled, it will be available at https://traefik.<DEV_DOMAIN>
# WARNING: Do not expose publicly without proper authentication.
TRAEFIK_DASHBOARD=true

# Enable/Disable automatic HTTP to HTTPS redirection (tests).
# If true, tests expect HTTP to redirect to HTTPS.
HTTP_TO_HTTPS_REDIRECT=true
# Middleware used for HTTP routers. Use redirect-to-https@file or noop@file.
HTTP_TO_HTTPS_MIDDLEWARE=redirect-to-https@file

# --- Shared CA Configuration (Modes A and C) ---

# Display name for the local CA (used by step-ca; also referenced in Mode A defaults).
CA_NAME="Local Dev CA"

# Subject fields for the local CA certificate (Mode A).
CA_SUBJECT_C=US
CA_SUBJECT_ST=Local
CA_SUBJECT_L=Local
CA_SUBJECT_O="Local Dev CA"
CA_SUBJECT_CN=LocalDevRootCA

# DNS/IP entries used to bootstrap Step-CA (Mode C).
# Used as SANs in Mode A if LEAF_* values are not overridden.
CA_DNS=step-ca,localhost,step-ca.${DEV_DOMAIN}
CA_IPS=127.0.0.1

# Leaf certificate subject/SANs (Mode A).
LEAF_SUBJECT_O="Local Dev"
LEAF_SUBJECT_CN="*.${DEV_DOMAIN}"
LEAF_DNS=whoami.${DEV_DOMAIN},traefik.${DEV_DOMAIN},step-ca.${DEV_DOMAIN},localhost
LEAF_IPS=127.0.0.1

# --- TLS Mode A (Local Self-Signed) Configuration ---

# Uses shared CA configuration values above.

# --- TLS Mode B (Let's Encrypt with Certbot) Configuration ---

# Email for Let's Encrypt notifications (required for certbot issuance).
# Used by Traefik's ACME resolver when 'le' profile is active.
ACME_EMAIL=you@example.com

# Use Let's Encrypt staging environment (true/false).
# Set to 'true' for testing to avoid hitting rate limits on production.
# Set to 'false' only when you are ready to get production certificates.
LETSENCRYPT_STAGING=true

# ACME directory URL for Let's Encrypt (used by Traefik's ACME client and certbot).
# Use staging for testing to avoid rate limits.
# Production: https://acme-v02.api.letsencrypt.org/directory
# Staging: https://acme-staging-v02.api.letsencrypt.org/directory
LETSENCRYPT_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# Optional comma-separated domain list for Certbot issuance (uses -d args).
# If empty, defaults to: DEV_DOMAIN, whoami.<DEV_DOMAIN>, traefik.<DEV_DOMAIN>, step-ca.<DEV_DOMAIN>
CERTBOT_DOMAINS=

# --- TLS Mode C (Step-CA) Configuration ---

# Legacy name for your Step-CA instance (optional).
# Prefer CA_NAME in the shared CA configuration section.
STEP_CA_NAME=

# Legacy DNS names/IPs for Step-CA certificates (bootstrap only).
# Prefer CA_DNS/CA_IPS in the shared CA configuration section.
STEP_CA_DNS=

# Enable SSH CA support during bootstrap (not needed for ACME).
STEP_CA_ENABLE_SSH=false

# ACME directory URL for Step-CA (used by Traefik's ACME resolver in Mode C).
STEP_CA_CA_SERVER=https://step-ca.${DEV_DOMAIN}:9000/acme/acme/directory

# Passwords for Step-CA (for initial bootstrap only).
# Leave blank to auto-generate via `make bootstrap`.
# IMPORTANT: These are used *only* during the `stepca-bootstrap` command.
#            They are NOT used by the running step-ca service directly.
# Password for the admin provisioner.
STEP_CA_ADMIN_PROVISIONER_PASSWORD=
# Password to encrypt the CA private key.
STEP_CA_PASSWORD=

# --- Internal Configuration (usually leave as-is) ---

# This variable is dynamically set by the Makefile based on the active profile.
# It tells Traefik which certificate resolver to use for ACME challenges.
# For Mode A (default), it's empty, relying on file-based TLS config.
# For Mode B (LE), it becomes 'le-resolver'.
# For Mode C (step-ca), it becomes 'stepca-resolver'.
TLS_CERT_RESOLVER=

# The COMPOSE_PROFILES environment variable is used by Docker Compose to activate
# specific services. It should be set when running `make up` or `make <profile>-up`.
# Example: COMPOSE_PROFILES=le
# Example: COMPOSE_PROFILES=stepca
# Example: COMPOSE_PROFILES=rocketchat
# Example: COMPOSE_PROFILES=le,stepca (for combining profiles, though not typically needed for cert modes)
COMPOSE_PROFILES=le,stepca
