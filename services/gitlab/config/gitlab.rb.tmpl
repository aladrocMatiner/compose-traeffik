# Managed by scripts/gitlab-render-config.sh
# Regenerate with: make gitlab-bootstrap

external_url '__GITLAB_EXTERNAL_URL__'

nginx['listen_port'] = 80
nginx['listen_https'] = false
nginx['proxy_set_headers'] = {
  "X-Forwarded-Proto" => "https",
  "X-Forwarded-Ssl" => "on"
}

# Git SSH clone URLs should use the host port published by docker compose.
gitlab_rails['gitlab_shell_ssh_port'] = __GITLAB_SSH_PORT__

# Seed root password on first boot. Subsequent changes require GitLab user management.
gitlab_rails['initial_root_password'] = "__GITLAB_ROOT_PASSWORD__"

__GITLAB_OIDC_BLOCK__

__GITLAB_OBSERVABILITY_BLOCK__
