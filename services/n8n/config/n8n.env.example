# Fallback env file so compose config parsing works before n8n-bootstrap.
# scripts/n8n-render-config.sh overwrites services/n8n/rendered/n8n.env with real values.
N8N_RENDER_STATUS=placeholder
N8N_PORT=5678
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=n8n-db
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=placeholder
N8N_ENCRYPTION_KEY=placeholder
N8N_HOST=n8n
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.local.test/
N8N_EDITOR_BASE_URL=https://n8n.local.test/
N8N_PROXY_HOPS=1
N8N_METRICS=false
NODE_EXTRA_CA_CERTS=
