# Fallback Rocket.Chat env file used only for compose parsing/default profile runs.
# The real runtime file should be rendered by `make rocketchat-bootstrap` and referenced by
# ROCKETCHAT_RENDERED_ENV_PATH when the `rocketchat` profile is enabled.
ROOT_URL=https://rocketchat.local.test
PORT=3000
DEPLOY_METHOD=docker
DEPLOY_PLATFORM=compose-traeffik
REG_TOKEN=
MONGO_URL=mongodb://rocketchat-mongodb:27017/rocketchat?replicaSet=rs0
MONGO_OPLOG_URL=mongodb://rocketchat-mongodb:27017/local?replicaSet=rs0
TRANSPORTER=monolith+nats://rocketchat-nats:4222
INSTANCE_IP=
OVERWRITE_SETTING_Site_Url=https://rocketchat.local.test
OVERWRITE_SETTING_Prometheus_Enabled=false
OVERWRITE_SETTING_Prometheus_Port=9458
