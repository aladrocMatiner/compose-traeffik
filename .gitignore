# .gitignore for Traefik Docker Compose Edge Stack

# --- Generated sensitive files and directories ---
# Certificates and keys
certs/
shared/certs/local-ca/
shared/certs/local/

# Certbot data
services/certbot/conf/
services/certbot/www/

# Step-CA data and config
services/step-ca/config/
services/step-ca/secrets/
services/step-ca/certs/
stepca-data/

# Traefik ACME storage (from certs-data volume)
# Although a Docker volume, local paths *could* be inadvertently created or referenced.
# Better to explicitly ignore any local files that might match these patterns.
acme-le.json
acme-stepca.json

# Traefik BasicAuth credentials
services/traefik/auth/*.htpasswd
!services/traefik/auth/*.htpasswd.example

# Rendered Traefik dynamic config
services/traefik/traefik-rendered.yml
services/traefik/dynamic-rendered/
services/gitlab/rendered/
services/n8n/rendered/
services/wikijs/rendered/

# Legacy local DNS artifacts from prior branches/runs
services/dns/
services/dns-bind/zones/db.aladroc.io

# --- Environment files ---
.env

# --- Local development artifacts ---
# macOS
.DS_Store

# IDEs and editors
.idea/
.vscode/
*.swp
*~

# Build artifacts
*.log
*.tmp

# --- Terraform / IaC local artifacts ---
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
deployment/state/
infra/terraform/state/
infra/images/
.tools/
