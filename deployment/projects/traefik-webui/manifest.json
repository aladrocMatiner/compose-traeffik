{
  "id": "traefik-webui",
  "description": "Deploy OpenWebUI behind Traefik with StepCA ACME defaults.",
  "repo_url": "https://github.com/aladrocMatiner/compose-traeffik.git",
  "repo_ref": "32cca31f3f3fc47f7f4d506fff69c0fc0ed10ecf",
  "compose_profile": "webui",
  "services": [
    "traefik",
    "openwebui"
  ],
  "deploy_playbook": "deployment/ansible/playbooks/project_deploy.yml",
  "required_env": [
    "BASE_DOMAIN",
    "DEV_DOMAIN"
  ],
  "tls_mode": "stepca-acme",
  "depends_on_projects": [
    "traefik-stepca"
  ],
  "public_host": "openwebui.local.test"
}
