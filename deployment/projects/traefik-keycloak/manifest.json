{
  "id": "traefik-keycloak",
  "description": "Deploy Keycloak behind Traefik with StepCA ACME defaults.",
  "repo_url": "https://github.com/aladrocMatiner/compose-traeffik.git",
  "repo_ref": "aa6cc1331491b6e73ce7d5d63c9e713d55e93d94",
  "compose_profile": "keycloak",
  "services": [
    "traefik",
    "whoami",
    "keycloak"
  ],
  "deploy_playbook": "deployment/ansible/playbooks/project_deploy.yml",
  "required_env": [
    "BASE_DOMAIN",
    "DEV_DOMAIN",
    "KEYCLOAK_ADMIN",
    "KEYCLOAK_ADMIN_PASSWORD",
    "STEP_CA_ADMIN_PROVISIONER_PASSWORD",
    "STEP_CA_PASSWORD"
  ],
  "tls_mode": "stepca-acme",
  "depends_on_projects": [
    "traefik-stepca"
  ],
  "public_host": "keycloak.local.test"
}
